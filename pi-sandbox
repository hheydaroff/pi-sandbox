#!/bin/bash
# Initialize pi DevContainer sandbox in the current directory
#
# Usage: pi-sandbox [options]
#   -f, --force        Overwrite existing .devcontainer
#   -o, --open         Open in VS Code after setup
#   -p, --provider     Auth provider: bedrock, anthropic, openai, subscription
#   -r, --region       AWS region (for Bedrock), default: eu-central-1
#   -m, --mount        Add extra mount path (can be used multiple times)
#   --no-docker        Disable Docker socket mount
#   --reconfigure      Re-run configuration prompts
#   -h, --help         Show this help message

set -e

# Self-locating: find .devcontainer relative to this script (works with symlinks)
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
TEMPLATE_DIR="$SCRIPT_DIR/.devcontainer"
CONFIG_DIR="$HOME/.config/pi-sandbox"
CONFIG_FILE="$CONFIG_DIR/config"
TARGET_DIR=".devcontainer"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Default values
FORCE=false
OPEN_VSCODE=false
RECONFIGURE=false
EXTRA_MOUNTS=()

# Load saved config
load_config() {
  PI_PROVIDER=""
  AWS_REGION="eu-central-1"
  DOCKER_ENABLED="true"

  if [ -f "$CONFIG_FILE" ]; then
    local val
    val=$(grep -E '^PI_PROVIDER=' "$CONFIG_FILE" | head -1 | cut -d'=' -f2-)
    [ -n "$val" ] && PI_PROVIDER="$val"
    val=$(grep -E '^AWS_REGION=' "$CONFIG_FILE" | head -1 | cut -d'=' -f2-)
    [ -n "$val" ] && AWS_REGION="$val"
    val=$(grep -E '^DOCKER_ENABLED=' "$CONFIG_FILE" | head -1 | cut -d'=' -f2-)
    [ -n "$val" ] && DOCKER_ENABLED="$val"
  fi
}

# Prompt for choice
prompt_choice() {
  local question="$1"
  shift
  local options=("$@")

  echo -e "${BOLD}$question${NC}"
  echo ""

  local i=1
  for opt in "${options[@]}"; do
    echo -e "  ${CYAN}[$i]${NC} $opt"
    ((i++))
  done

  echo ""
  while true; do
    read -p "Choice [1-${#options[@]}]: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#options[@]}" ]; then
      REPLY=$choice
      return 0
    fi
    echo -e "${RED}Invalid choice. Please enter a number between 1 and ${#options[@]}.${NC}"
  done
}

# Run configuration prompts
run_configuration() {
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${BLUE}  Pi Sandbox Configuration${NC}"
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""

  # Auth method
  prompt_choice "How will you authenticate with pi?" \
    "AWS Bedrock (AWS credentials)" \
    "Anthropic API key (ANTHROPIC_API_KEY)" \
    "OpenAI API key (OPENAI_API_KEY)" \
    "Subscription (Claude Pro/Max, ChatGPT Plus — run /login in container)"

  case $REPLY in
    1) PI_PROVIDER="bedrock" ;;
    2) PI_PROVIDER="anthropic" ;;
    3) PI_PROVIDER="openai" ;;
    4) PI_PROVIDER="subscription" ;;
  esac

  echo ""

  # Region (Bedrock only)
  if [ "$PI_PROVIDER" = "bedrock" ]; then
    prompt_choice "Select your AWS Bedrock region:" \
      "us-east-1 (N. Virginia)" \
      "us-west-2 (Oregon)" \
      "eu-central-1 (Frankfurt)" \
      "eu-west-1 (Ireland)" \
      "eu-west-3 (Paris)" \
      "ap-northeast-1 (Tokyo)" \
      "ap-southeast-1 (Singapore)" \
      "ap-southeast-2 (Sydney)"

    case $REPLY in
      1) AWS_REGION="us-east-1" ;;
      2) AWS_REGION="us-west-2" ;;
      3) AWS_REGION="eu-central-1" ;;
      4) AWS_REGION="eu-west-1" ;;
      5) AWS_REGION="eu-west-3" ;;
      6) AWS_REGION="ap-northeast-1" ;;
      7) AWS_REGION="ap-southeast-1" ;;
      8) AWS_REGION="ap-southeast-2" ;;
    esac

    echo ""
  fi

  # Docker detection
  if [ -S "/var/run/docker.sock" ]; then
    DOCKER_ENABLED="true"
  else
    DOCKER_ENABLED="false"
  fi

  # Save config
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" << EOF
# Pi Sandbox Configuration
PI_PROVIDER=$PI_PROVIDER
AWS_REGION=$AWS_REGION
DOCKER_ENABLED=$DOCKER_ENABLED
EOF
  chmod 600 "$CONFIG_FILE"

  echo -e "${GREEN}Configuration saved!${NC}"
  echo ""
}

# Sync pi configuration to .pi-config/ (to be mounted into container)
sync_pi_config() {
  local CONFIG_TARGET=".pi-config"
  local PI_SOURCE="$HOME/.pi/agent"

  # Detect ~/.claude/skills so devcontainer.json and settings.json can reference it
  if [ -d "$HOME/.claude/skills" ]; then
    CLAUDE_SKILLS_FOUND="true"
  else
    CLAUDE_SKILLS_FOUND="false"
  fi

  echo -e "${GREEN}Syncing pi configuration...${NC}"
  mkdir -p "$CONFIG_TARGET/skills"
  mkdir -p "$CONFIG_TARGET/prompts"
  mkdir -p "$CONFIG_TARGET/extensions"
  mkdir -p "$CONFIG_TARGET/themes"

  # Copy AGENTS.md (global context instructions)
  if [ -f "$PI_SOURCE/AGENTS.md" ]; then
    cp "$PI_SOURCE/AGENTS.md" "$CONFIG_TARGET/"
    echo "  Copied: AGENTS.md"
  fi

  # Copy CLAUDE.md as well if present (pi supports both)
  if [ -f "$PI_SOURCE/CLAUDE.md" ]; then
    cp "$PI_SOURCE/CLAUDE.md" "$CONFIG_TARGET/"
    echo "  Copied: CLAUDE.md"
  fi

  # Copy models.json (custom provider/model definitions e.g. LM Studio)
  if [ -f "$PI_SOURCE/models.json" ]; then
    cp "$PI_SOURCE/models.json" "$CONFIG_TARGET/"
    echo "  Copied: models.json"
  fi

  # Copy skills directory
  if [ -d "$PI_SOURCE/skills" ] && [ "$(ls -A "$PI_SOURCE/skills" 2>/dev/null)" ]; then
    cp -R "$PI_SOURCE/skills/"* "$CONFIG_TARGET/skills/" 2>/dev/null || true
    local skill_count
    skill_count=$(find "$CONFIG_TARGET/skills" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    echo "  Copied: skills/ ($skill_count skills)"
  fi

  # Copy prompts directory
  if [ -d "$PI_SOURCE/prompts" ] && [ "$(ls -A "$PI_SOURCE/prompts" 2>/dev/null)" ]; then
    cp -R "$PI_SOURCE/prompts/"* "$CONFIG_TARGET/prompts/" 2>/dev/null || true
    local prompt_count
    prompt_count=$(find "$CONFIG_TARGET/prompts" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    echo "  Copied: prompts/ ($prompt_count templates)"
  fi

  # Copy extensions directory
  if [ -d "$PI_SOURCE/extensions" ] && [ "$(ls -A "$PI_SOURCE/extensions" 2>/dev/null)" ]; then
    cp -R "$PI_SOURCE/extensions/"* "$CONFIG_TARGET/extensions/" 2>/dev/null || true
    local ext_count
    ext_count=$(find "$CONFIG_TARGET/extensions" -maxdepth 1 -name "*.ts" -o -maxdepth 1 -name "*.js" 2>/dev/null | wc -l | tr -d ' ')
    echo "  Copied: extensions/ ($ext_count extensions)"
  fi

  # Copy themes directory
  if [ -d "$PI_SOURCE/themes" ] && [ "$(ls -A "$PI_SOURCE/themes" 2>/dev/null)" ]; then
    cp -R "$PI_SOURCE/themes/"* "$CONFIG_TARGET/themes/" 2>/dev/null || true
    local theme_count
    theme_count=$(find "$CONFIG_TARGET/themes" -name "*.json" 2>/dev/null | wc -l | tr -d ' ')
    echo "  Copied: themes/ ($theme_count themes)"
  fi

  # Generate settings.json based on provider
  generate_pi_settings "$CONFIG_TARGET"

  echo ""
}

# Generate ~/.pi/agent/settings.json for the container
generate_pi_settings() {
  local CONFIG_TARGET="$1"

  # Build optional skills array pointing at the mounted ~/.claude/skills
  local skills_block=""
  if [ "$CLAUDE_SKILLS_FOUND" = "true" ]; then
    skills_block=',
  "skills": ["~/.claude/skills"]'
    echo "  Linked:    ~/.claude/skills → settings.json skills[]"
  fi

  case "$PI_PROVIDER" in
    bedrock)
      local model_prefix=""
      case "$AWS_REGION" in
        us-east-1|us-west-2) model_prefix="us" ;;
        eu-*) model_prefix="eu" ;;
        ap-*) model_prefix="ap" ;;
        *) model_prefix="us" ;;
      esac

      cat > "$CONFIG_TARGET/settings.json" << EOF
{
  "defaultProvider": "amazon-bedrock",
  "defaultModel": "${model_prefix}.anthropic.claude-sonnet-4-6",
  "defaultThinkingLevel": "medium",
  "theme": "dark"${skills_block}
}
EOF
      echo "  Generated: settings.json (Bedrock / ${AWS_REGION})"
      ;;

    anthropic)
      cat > "$CONFIG_TARGET/settings.json" << EOF
{
  "defaultProvider": "anthropic",
  "defaultModel": "claude-sonnet-4-5",
  "defaultThinkingLevel": "medium",
  "theme": "dark"${skills_block}
}
EOF
      echo "  Generated: settings.json (Anthropic API)"
      ;;

    openai)
      cat > "$CONFIG_TARGET/settings.json" << EOF
{
  "defaultProvider": "openai",
  "defaultModel": "gpt-4o",
  "defaultThinkingLevel": "off",
  "theme": "dark"${skills_block}
}
EOF
      echo "  Generated: settings.json (OpenAI API)"
      ;;

    subscription)
      # Leave provider/model unset so user picks via /login
      cat > "$CONFIG_TARGET/settings.json" << EOF
{
  "defaultThinkingLevel": "medium",
  "theme": "dark"${skills_block}
}
EOF
      echo "  Generated: settings.json (subscription — run /login to authenticate)"
      ;;
  esac
}

# Generate devcontainer.json
generate_devcontainer() {
  local mounts_json=""
  local env_json=""
  local post_create_cmd=""

  # Always mount gitconfig (read-only)
  mounts_json='"source=${localEnv:HOME}/.gitconfig,target=/home/developer/.gitconfig,type=bind,readonly"'

  # Docker mount (if enabled)
  if [ "$DOCKER_ENABLED" = "true" ]; then
    mounts_json="$mounts_json,
    \"source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind\""
  fi

  # Extra mounts
  for mount_path in "${EXTRA_MOUNTS[@]}"; do
    local mount_name
    mount_name=$(basename "$mount_path")
    # Sanitize: reject paths with characters that would break JSON or the mount spec
    if [[ "$mount_path" =~ [\"\'\\,\`] ]] || [[ "$mount_name" =~ [\"\'\\,\`] ]]; then
      echo -e "${RED}Error: mount path contains invalid characters: $mount_path${NC}"
      exit 1
    fi
    mounts_json="$mounts_json,
    \"source=$mount_path,target=/mnt/$mount_name,type=bind\""
  done

  # Pi config sync mount (read-only, synced from host)
  mounts_json="$mounts_json,
    \"source=\${localWorkspaceFolder}/.pi-config,target=/home/developer/.pi-sync,type=bind,readonly\""

  # Mount ~/.claude/skills directly if it exists on the host (live link, no copy needed)
  if [ "$CLAUDE_SKILLS_FOUND" = "true" ]; then
    mounts_json="$mounts_json,
    \"source=\${localEnv:HOME}/.claude/skills,target=/home/developer/.claude/skills,type=bind,readonly\""
  fi

  # Config sync command: copies .pi-sync contents into ~/.pi/agent/
  local config_sync_cmd="if [ -d ~/.pi-sync ]; then \
mkdir -p ~/.pi/agent/skills ~/.pi/agent/prompts ~/.pi/agent/extensions ~/.pi/agent/themes && \
cp -f ~/.pi-sync/AGENTS.md ~/.pi/agent/ 2>/dev/null || true && \
cp -f ~/.pi-sync/CLAUDE.md ~/.pi/agent/ 2>/dev/null || true && \
cp -f ~/.pi-sync/models.json ~/.pi/agent/ 2>/dev/null || true && \
cp -f ~/.pi-sync/settings.json ~/.pi/agent/ 2>/dev/null || true && \
cp -R ~/.pi-sync/skills/. ~/.pi/agent/skills/ 2>/dev/null || true && \
cp -R ~/.pi-sync/prompts/. ~/.pi/agent/prompts/ 2>/dev/null || true && \
cp -R ~/.pi-sync/extensions/. ~/.pi/agent/extensions/ 2>/dev/null || true && \
cp -R ~/.pi-sync/themes/. ~/.pi/agent/themes/ 2>/dev/null || true && \
echo 'Pi config synced from host'; fi && "

  # Environment variables and post-create command based on provider
  case "$PI_PROVIDER" in
    bedrock)
      local model_prefix=""
      case "$AWS_REGION" in
        us-east-1|us-west-2) model_prefix="us" ;;
        eu-*) model_prefix="eu" ;;
        ap-*) model_prefix="ap" ;;
        *) model_prefix="us" ;;
      esac

      env_json="\"AWS_DEFAULT_REGION\": \"$AWS_REGION\",
    \"AWS_REGION\": \"$AWS_REGION\""

      post_create_cmd="${config_sync_cmd}npm config set prefix \$HOME/.local && npm install -g @mariozechner/pi-coding-agent && \
echo 'export PATH=\\\"\$HOME/.local/bin:\$PATH\\\"' >> ~/.bashrc && \
echo '' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━' && \
echo '  Pi Sandbox ready!' && \
echo '  Config synced: AGENTS.md, skills, prompts, extensions, themes' && \
echo '  Provider: AWS Bedrock ($AWS_REGION)' && \
echo '  Run: export AWS_ACCESS_KEY_ID=... && export AWS_SECRET_ACCESS_KEY=...' && \
echo '  Then: pi' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'"
      ;;

    anthropic)
      env_json=""
      post_create_cmd="${config_sync_cmd}npm config set prefix \$HOME/.local && npm install -g @mariozechner/pi-coding-agent && \
echo 'export PATH=\\\"\$HOME/.local/bin:\$PATH\\\"' >> ~/.bashrc && \
echo '' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━' && \
echo '  Pi Sandbox ready!' && \
echo '  Config synced: AGENTS.md, skills, prompts, extensions, themes' && \
echo '  Provider: Anthropic API' && \
echo '  Run: export ANTHROPIC_API_KEY=sk-ant-...' && \
echo '  Then: pi' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'"
      ;;

    openai)
      env_json=""
      post_create_cmd="${config_sync_cmd}npm config set prefix \$HOME/.local && npm install -g @mariozechner/pi-coding-agent && \
echo 'export PATH=\\\"\$HOME/.local/bin:\$PATH\\\"' >> ~/.bashrc && \
echo '' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━' && \
echo '  Pi Sandbox ready!' && \
echo '  Config synced: AGENTS.md, skills, prompts, extensions, themes' && \
echo '  Provider: OpenAI API' && \
echo '  Run: export OPENAI_API_KEY=sk-...' && \
echo '  Then: pi' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'"
      ;;

    subscription)
      env_json=""
      post_create_cmd="${config_sync_cmd}npm config set prefix \$HOME/.local && npm install -g @mariozechner/pi-coding-agent && \
echo 'export PATH=\\\"\$HOME/.local/bin:\$PATH\\\"' >> ~/.bashrc && \
echo '' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━' && \
echo '  Pi Sandbox ready!' && \
echo '  Config synced: AGENTS.md, skills, prompts, extensions, themes' && \
echo '  Provider: Subscription' && \
echo '  Run: pi' && \
echo '  Then inside pi: /login  (select your provider)' && \
echo '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━'"
      ;;
  esac

  # Build containerEnv section
  local container_env=""
  if [ -n "$env_json" ]; then
    container_env="\"containerEnv\": {
    $env_json
  },"
  fi

  # Write devcontainer.json
  cat > "$TARGET_DIR/devcontainer.json" << EOF
{
  "name": "Pi Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.fontSize": 14
      }
    }
  },
  "mounts": [
    $mounts_json
  ],
  $container_env
  "remoteUser": "developer",
  "postCreateCommand": "$post_create_cmd"
}
EOF
}

# Create or update .gitignore
create_gitignore() {
  local gitignore_file=".gitignore"
  local entries=(
    ".devcontainer/"
    ".pi-config/"
    ".pi/"
    ".vscode/"
    ".env"
    ".env.*"
  )

  echo -e "${GREEN}Updating .gitignore...${NC}"
  touch "$gitignore_file"

  if ! grep -q "# Pi Sandbox" "$gitignore_file" 2>/dev/null; then
    echo "" >> "$gitignore_file"
    echo "# Pi Sandbox" >> "$gitignore_file"
  fi

  for entry in "${entries[@]}"; do
    if ! grep -qxF "$entry" "$gitignore_file" 2>/dev/null; then
      echo "$entry" >> "$gitignore_file"
      echo "  Added: $entry"
    fi
  done

  echo ""
}

# Show help
show_help() {
  echo "Initialize pi DevContainer sandbox in the current directory"
  echo ""
  echo "Usage: pi-sandbox [options]"
  echo ""
  echo "Options:"
  echo "  -f, --force        Overwrite existing .devcontainer"
  echo "  -o, --open         Open in VS Code after setup"
  echo "  -p, --provider     Auth provider: bedrock, anthropic, openai, subscription"
  echo "  -r, --region       AWS region (for Bedrock): eu-central-1, us-east-1, etc."
  echo "  -m, --mount        Add extra mount path (can be used multiple times)"
  echo "  --no-docker        Disable Docker socket mount"
  echo "  --reconfigure      Re-run configuration prompts"
  echo "  -h, --help         Show this help message"
  echo ""
  echo "Examples:"
  echo "  pi-sandbox                              # Use saved defaults"
  echo "  pi-sandbox --provider anthropic         # Override to Anthropic API key"
  echo "  pi-sandbox --provider bedrock --region eu-central-1"
  echo "  pi-sandbox --mount /path/to/data        # Add extra mount"
  echo "  pi-sandbox --no-docker                  # Disable Docker access"
  echo ""
  echo "Config file: $CONFIG_FILE"
}

# Parse arguments
parse_args() {
  while [[ $# -gt 0 ]]; do
    case $1 in
      -f|--force)
        FORCE=true
        shift
        ;;
      -o|--open)
        OPEN_VSCODE=true
        shift
        ;;
      -p|--provider)
        case "$2" in
          bedrock|anthropic|openai|subscription)
            PI_PROVIDER="$2"
            ;;
          *)
            echo -e "${RED}Invalid provider: $2. Must be one of: bedrock, anthropic, openai, subscription${NC}"
            exit 1
            ;;
        esac
        shift 2
        ;;
      -r|--region)
        case "$2" in
          us-east-1|us-west-2|eu-central-1|eu-west-1|eu-west-3|ap-northeast-1|ap-southeast-1|ap-southeast-2)
            AWS_REGION="$2"
            ;;
          *)
            echo -e "${RED}Invalid region: $2. Must be one of: us-east-1, us-west-2, eu-central-1, eu-west-1, eu-west-3, ap-northeast-1, ap-southeast-1, ap-southeast-2${NC}"
            exit 1
            ;;
        esac
        shift 2
        ;;
      -m|--mount)
        EXTRA_MOUNTS+=("$2")
        shift 2
        ;;
      --no-docker)
        DOCKER_ENABLED="false"
        shift
        ;;
      --reconfigure)
        RECONFIGURE=true
        shift
        ;;
      -h|--help)
        show_help
        exit 0
        ;;
      *)
        echo -e "${RED}Unknown option: $1${NC}"
        echo "Use --help for usage information."
        exit 1
        ;;
    esac
  done
}

# Main
main() {
  load_config
  parse_args "$@"

  # Run configuration if no provider is set or reconfigure requested
  if [ -z "$PI_PROVIDER" ] || [ "$RECONFIGURE" = true ]; then
    run_configuration
  fi

  # Check that Dockerfile template exists
  if [ ! -f "$TEMPLATE_DIR/Dockerfile" ]; then
    echo -e "${RED}Error: Dockerfile template not found at $TEMPLATE_DIR${NC}"
    echo "This usually means the installation is incomplete."
    echo "Please clone the repo and run install.sh:"
    echo "  git clone https://github.com/hheydaroff/pi-sandbox.git"
    echo "  cd pi-sandbox && ./install.sh"
    exit 1
  fi

  # Check if .devcontainer already exists
  if [ -d "$TARGET_DIR" ] && [ "$FORCE" = false ]; then
    echo -e "${YELLOW}Warning: .devcontainer already exists in this directory.${NC}"
    echo "Use -f or --force to overwrite."
    exit 1
  fi

  echo -e "${GREEN}Setting up pi sandbox...${NC}"
  mkdir -p "$TARGET_DIR"

  # Sync pi configuration from host ~/.pi/agent/
  sync_pi_config

  # Copy Dockerfile and ralph.sh (both needed for docker build context)
  cp "$TEMPLATE_DIR/Dockerfile" "$TARGET_DIR/Dockerfile"
  cp "$TEMPLATE_DIR/ralph.sh" "$TARGET_DIR/ralph.sh"

  # Generate devcontainer.json
  generate_devcontainer

  # Create/update .gitignore
  create_gitignore

  # Success message
  echo ""
  echo -e "${GREEN}DevContainer created at .devcontainer/${NC}"
  echo ""
  echo "Files created:"
  echo "  .devcontainer/devcontainer.json"
  echo "  .devcontainer/Dockerfile"
  echo "  .devcontainer/ralph.sh"
  echo "  .pi-config/settings.json"
  [ -f ".pi-config/AGENTS.md" ]   && echo "  .pi-config/AGENTS.md"
  [ -f ".pi-config/CLAUDE.md" ]   && echo "  .pi-config/CLAUDE.md"
  [ -f ".pi-config/models.json" ] && echo "  .pi-config/models.json"
  [ "$CLAUDE_SKILLS_FOUND" = "true" ] && echo "  ~/.claude/skills → mounted (live link)"
  echo "  .gitignore (updated)"
  echo ""
  echo "Configuration:"
  echo -e "  Provider: ${CYAN}$PI_PROVIDER${NC}"
  if [ "$PI_PROVIDER" = "bedrock" ]; then
    echo -e "  Region:   ${CYAN}$AWS_REGION${NC}"
  fi
  echo -e "  Docker:   ${CYAN}$DOCKER_ENABLED${NC}"
  if [ ${#EXTRA_MOUNTS[@]} -gt 0 ]; then
    echo -e "  Mounts:   ${CYAN}${EXTRA_MOUNTS[*]}${NC}"
  fi
  echo ""
  echo -e "${YELLOW}Next steps:${NC}"
  echo "  1. Open this folder in VS Code"
  echo "  2. Cmd+Shift+P → 'Dev Containers: Reopen in Container'"
  case "$PI_PROVIDER" in
    bedrock)
      echo "  3. In container: export AWS_ACCESS_KEY_ID=... && export AWS_SECRET_ACCESS_KEY=..."
      echo "  4. Run: pi"
      ;;
    anthropic)
      echo "  3. In container: export ANTHROPIC_API_KEY=sk-ant-..."
      echo "  4. Run: pi"
      ;;
    openai)
      echo "  3. In container: export OPENAI_API_KEY=sk-..."
      echo "  4. Run: pi"
      ;;
    subscription)
      echo "  3. Run: pi"
      echo "  4. Inside pi: /login  (then select your provider)"
      ;;
  esac

  # Open in VS Code if requested
  if [ "$OPEN_VSCODE" = true ]; then
    echo ""
    echo -e "${GREEN}Opening in VS Code DevContainer...${NC}"

    if command -v devcontainer &> /dev/null; then
      echo "  Using devcontainer CLI..."
      devcontainer open "$(pwd)"
    elif command -v code &> /dev/null; then
      code .
      echo ""
      echo -e "${YELLOW}Tip: Press Cmd+Shift+P and select 'Dev Containers: Reopen in Container'${NC}"
    else
      echo -e "${YELLOW}VS Code 'code' command not found in PATH${NC}"
      echo "Install it from VS Code: Cmd+Shift+P → 'Shell Command: Install code command'"
    fi
  fi
}

main "$@"
